{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Final",
  "colors": {
    "primary": "#ff4e96",
    "light": "#ff4e96",
    "dark": "#ff4e96"
  },
  "favicon": {
    "light": "/images/favicon.svg",
    "dark": "/images/favicon.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "quickstart"
        ]
      },
      {
        "group": "API Reference",
        "openapi": "/openapi.public.json"
      }
    ]
  },
  "logo": {
    "light": "/images/final-light.svg",
    "dark": "/images/final-dark.svg",
    "href": "https://final.net"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@final.net"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/usefinal",
      "github": "https://github.com/final-net",
      "linkedin": "https://linkedin.com/company/usefinal"
    }
  },
  "description": "How machines move money.",
  "icons": {
    "library": "tabler"
  },
  "fonts": {
    "family": "GT Mechanik Semi",
    "weight": 500,
    "source": "https://final.net/assets/fonts/GT-Mechanik-Semi-Medium.woff2",
    "format": "woff2"
  }
}
